# ============================================================
#  PLANTILLA DE PRODUCCIÓN — rrhh.gds.pe (yachay / cPanel)
# ------------------------------------------------------------
#  Copia este archivo como  .env  en la RAÍZ del repo en el
#  servidor (vía File Manager) y llena los valores marcados.
#  El .env real NUNCA se sube a git (está en .gitignore).
# ============================================================

APP_NAME="Sistema RRHH"
APP_ENV=production
# Pega aquí la APP_KEY que te dio Claude (base64:...). NO la dejes vacía.
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Lima
APP_URL=https://rrhh.gds.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

# Token de instalación de un solo uso (ruta /_setup/{token}).
# Ponlo SOLO durante el despliegue; luego déjalo vacío y vuelve a desplegar.
APP_SETUP_TOKEN=

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ---- Base de datos (créala en cPanel > MySQL Databases) ----
# cPanel antepone el usuario de la cuenta al nombre, ej: oipfutlf_rrhh
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oipfutlf_rrhh
DB_USERNAME=oipfutlf_rrhh
DB_PASSWORD=

# ---- Sesión / caché / colas: archivo (sin servicios extra) ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# ---- Correo (se configura después, con una cuenta de cPanel) ----
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=mail.gds.pe
# MAIL_PORT=465
# MAIL_USERNAME=rrhh@gds.pe
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="rrhh@gds.pe"
# MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
